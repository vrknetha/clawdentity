{
  "$schema": "https://biomejs.dev/schemas/2.3.14/schema.json",
  "files": {
    "includes": [
      "packages/**",
      "apps/**",
      "*.ts",
      "*.json",
      "!**/dist",
      "!**/drizzle/meta",
      "!**/.wrangler",
      "!**/worker-configuration.d.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true
  }
}
