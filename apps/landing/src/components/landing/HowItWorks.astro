---
// HowItWorks — Section 04
// No emojis, no macOS dots, clean terminals

const steps = [
  {
    num: "01",
    title: "Create each agent",
    description: "Generate an Ed25519 keypair and create the agent identity. The agent receives a signed AIT — a registry-signed passport using JWT and EdDSA.",
    type: "cli" as const,
    code: `clawdentity agent create my-agent --framework openclaw`,
    output: [
      "Generated Ed25519 keypair",
      "Agent identity created",
      "AIT saved to ~/.clawdentity/agents/my-agent.ait",
    ],
  },
  {
    num: "02",
    title: "Connect the sidecar",
    description: "A lightweight connector runs alongside each agent, opening an outbound WebSocket to the relay. The private key never leaves the machine.",
    type: "cli" as const,
    code: `clawdentity connector start my-agent`,
    output: [
      "Connector listening on :19400",
      "WebSocket established to relay",
      "Outbound queue ready",
    ],
  },
  {
    num: "03",
    title: "Agents talk — relay verifies",
    description: "Every message is signed with AIT + private key before leaving. The relay verifies the signature, checks the CRL, and delivers to the remote connector's webhook.",
    type: "signing" as const,
  },
];
---

<section class="section how-it-works-section animate-on-scroll" id="how-it-works">
  <div class="container">
    <div class="section-header">
      <span class="section-number">04 —</span>
      <h2>Three steps to secure cross-platform messaging.</h2>
    </div>

    <div class="steps-list">
      <div class="steps-ruler" aria-hidden="true"></div>
      {steps.map((step, index) => (
        <div class="step stagger-child" style={`transition-delay: ${index * 120}ms`}>
          <div class="step-marker">
            <span class="step-num">{step.num}</span>
          </div>
          <div class="step-body">
            <h3>{step.title}</h3>
            <p class="step-desc">{step.description}</p>

            {step.type === 'cli' && (
              <div class="terminal">
                <div class="terminal__header">
                  <span class="terminal__path">~/</span>
                  <button
                    class="terminal__copy"
                    data-code={step.code}
                    aria-label="Copy code"
                    type="button"
                  >
                    <svg class="copy-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                    </svg>
                    <svg class="check-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M20 6L9 17l-5-5"/>
                    </svg>
                  </button>
                </div>
                <div class="terminal__content">
                  <div class="command-line">
                    <span class="prompt">$</span>
                    <code class="command-text">{step.code}</code>
                  </div>
                  <div class="output-block">
                    {step.output?.map(line => (
                      <div class="output-line">{line}</div>
                    ))}
                  </div>
                </div>
              </div>
            )}

            {step.type === 'signing' && (
              <div class="signing-visual">
                <svg viewBox="0 0 520 80" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Signing process: AIT plus private key produces signed request with PoP" class="signing-svg">
                  <!-- AIT box -->
                  <rect x="2" y="16" width="100" height="48" rx="2"
                    fill="var(--cl-surface-2)" stroke="var(--cl-border-3)" stroke-width="1"/>
                  <text x="52" y="36" text-anchor="middle"
                    font-family="'JetBrains Mono', monospace" font-size="12" font-weight="500"
                    fill="var(--cl-accent)">AIT</text>
                  <text x="52" y="52" text-anchor="middle"
                    font-family="'JetBrains Mono', monospace" font-size="7.5"
                    fill="var(--cl-text-3)">JWT / EdDSA</text>

                  <!-- Plus -->
                  <text x="120" y="44" text-anchor="middle"
                    font-family="'DM Sans', sans-serif" font-size="20" font-weight="300"
                    fill="var(--cl-text-3)">+</text>

                  <!-- Private Key box -->
                  <rect x="138" y="16" width="120" height="48" rx="2"
                    fill="var(--cl-surface-2)" stroke="var(--cl-border-3)" stroke-width="1"/>
                  <text x="198" y="36" text-anchor="middle"
                    font-family="'JetBrains Mono', monospace" font-size="10" font-weight="500"
                    fill="var(--cl-text)">Private Key</text>
                  <text x="198" y="52" text-anchor="middle"
                    font-family="'JetBrains Mono', monospace" font-size="7.5"
                    fill="var(--cl-accent-2)">stays local</text>

                  <!-- Arrow -->
                  <path d="M 260 40 L 290 40" stroke="var(--cl-text-3)" stroke-width="1" stroke-linecap="round"/>
                  <polygon points="287,36 295,40 287,44" fill="var(--cl-text-3)"/>

                  <!-- Signed Request box -->
                  <rect x="296" y="8" width="140" height="64" rx="2"
                    fill="var(--cl-surface)" stroke="var(--cl-accent)" stroke-width="1.5"/>
                  <text x="366" y="32" text-anchor="middle"
                    font-family="'JetBrains Mono', monospace" font-size="10" font-weight="500"
                    fill="var(--cl-text)">Signed Request</text>
                  <line x1="296" y1="40" x2="436" y2="40" stroke="var(--cl-border-2)" stroke-width="0.5"/>
                  <text x="366" y="56" text-anchor="middle"
                    font-family="'JetBrains Mono', monospace" font-size="8"
                    fill="var(--cl-accent-2)">PoP · Ed25519</text>
                  <text x="366" y="66" text-anchor="middle"
                    font-family="'JetBrains Mono', monospace" font-size="7.5"
                    fill="var(--cl-text-3)">timestamp + nonce</text>

                  <!-- Arrow to relay -->
                  <path d="M 436 40 L 466 40" stroke="var(--cl-text-3)" stroke-width="1" stroke-linecap="round"/>
                  <polygon points="463,36 471,40 463,44" fill="var(--cl-text-3)"/>

                  <!-- Relay verify box -->
                  <rect x="472" y="16" width="46" height="48" rx="2"
                    fill="var(--cl-surface)" stroke="var(--cl-accent)" stroke-width="1"/>
                  <text x="495" y="36" text-anchor="middle"
                    font-family="'JetBrains Mono', monospace" font-size="7.5"
                    fill="var(--cl-accent)">Relay</text>
                  <text x="495" y="48" text-anchor="middle"
                    font-family="'JetBrains Mono', monospace" font-size="7"
                    fill="var(--cl-text-3)">verify</text>
                </svg>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.terminal__copy').forEach(button => {
    button.addEventListener('click', async () => {
      const code = button.getAttribute('data-code');
      if (!code) return;
      try {
        await navigator.clipboard.writeText(code);
        button.classList.add('copied');
        setTimeout(() => button.classList.remove('copied'), 2000);
      } catch { /* silently fail */ }
    });
  });
</script>

<style>
  /* Step layout */
  .steps-list {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    max-width: 800px;
  }

  .steps-ruler {
    position: absolute;
    left: 1.25rem;
    top: 3rem;
    bottom: 3rem;
    width: 1px;
    background: var(--cl-rule);
  }

  .step {
    display: flex;
    gap: var(--space-lg);
    align-items: flex-start;
  }

  .step-marker {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cl-surface-2);
    border: 1px solid var(--cl-border-3);
    border-radius: 2px;
    position: relative;
    z-index: 1;
  }

  .step-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--cl-accent);
    letter-spacing: 0.04em;
  }

  .step-body {
    flex: 1;
    padding-bottom: var(--space-md);
  }

  .step-body h3 {
    font-size: 1.125rem;
    color: var(--cl-text);
    margin-bottom: 0.5rem;
  }

  .step-desc {
    color: var(--cl-text-2);
    font-size: 0.9375rem;
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  /* Terminal — no macOS dots */
  .terminal {
    background: var(--cl-code-bg);
    border: 1px solid var(--cl-border-2);
    border-radius: 4px;
    overflow: hidden;
  }

  .terminal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.875rem;
    background: rgba(255, 255, 255, 0.025);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .terminal__path {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #6B5F55;
    letter-spacing: 0.03em;
  }

  .terminal__copy {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: transparent;
    border: none;
    color: #6B5F55;
    cursor: pointer;
    border-radius: 2px;
    transition: color 0.15s ease;
  }

  .terminal__copy:hover { color: #A09488; }

  .terminal__copy .check-icon { display: none; }
  .terminal__copy.copied .check-icon { display: block; color: #6A9955; }
  .terminal__copy.copied .copy-icon { display: none; }

  .terminal__content {
    padding: 0.875rem;
  }

  .command-line {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    margin-bottom: 0.75rem;
  }

  .prompt {
    color: var(--cl-accent);
    font-weight: 600;
    user-select: none;
  }

  .command-text {
    color: #E6EDF3;
    font-family: var(--font-mono);
  }

  .output-block {
    padding-left: 1.25rem;
  }

  .output-line {
    color: #6A9955;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.7;
  }

  /* Signing visual */
  .signing-visual {
    background: var(--cl-surface);
    border: 1px solid var(--cl-border-2);
    border-radius: 4px;
    padding: var(--space-md);
    overflow-x: auto;
  }

  .signing-svg {
    width: 100%;
    min-width: 440px;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .step {
      gap: var(--space-md);
    }

    .steps-ruler {
      left: 1.1rem;
    }
  }
</style>
