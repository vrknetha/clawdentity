---
import { Image } from "astro:assets";
import heroImage from "../../assets/landing/clawdentity_hero_2400x1200.png";
---

<section class="hero">
  <!-- Animated gradient background -->
  <div class="hero-gradient-bg"></div>
  
  <!-- Floating particles -->
  <div class="particles" id="particles">
    <div class="particle" style="top: 20%; left: 10%; animation-delay: 0s;"></div>
    <div class="particle particle--amber" style="top: 60%; left: 15%; animation-delay: 2s;"></div>
    <div class="particle" style="top: 30%; left: 85%; animation-delay: 4s;"></div>
    <div class="particle particle--amber" style="top: 70%; left: 80%; animation-delay: 1s;"></div>
    <div class="particle" style="top: 45%; left: 5%; animation-delay: 3s;"></div>
    <div class="particle particle--amber" style="top: 15%; left: 90%; animation-delay: 5s;"></div>
    <div class="particle" style="top: 80%; left: 50%; animation-delay: 2.5s;"></div>
    <div class="particle particle--amber" style="top: 25%; left: 70%; animation-delay: 1.5s;"></div>
  </div>

  <!-- Hero background image -->
  <div class="hero-bg">
    <Image
      src={heroImage}
      alt=""
      widths={[640, 960, 1280, 1920, 2400]}
      sizes="100vw"
      format="webp"
      quality={80}
      loading="eager"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content container">
    <h1 class="hero-title">
      <span class="gradient-text hero-line" data-animate>Who is this agent,</span>
      <span class="hero-line" data-animate>who owns it, and is it revoked?</span>
    </h1>
    <p class="hero-subtitle" data-animate>
      Clawdentity answers that question with verifiable per-agent identity,
      proof-of-possession on every request, and instant revocation
      that propagates in seconds.
    </p>
    <div class="hero-actions" data-animate>
      <a href="/getting-started/quickstart/" class="btn btn-primary animate-pulse-glow">
        Get Started
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="https://github.com/vrknetha/clawdentity" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        View on GitHub
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" id="scroll-indicator">
    <span>Scroll to explore</span>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 5v14M19 12l-7 7-7-7"/>
    </svg>
  </div>
</section>

<script>
  // Hero text reveal animation
  (function() {
    const animateElements = document.querySelectorAll('[data-animate]');
    
    // Trigger animations after a short delay for page load
    setTimeout(() => {
      animateElements.forEach((el, index) => {
        setTimeout(() => {
          el.classList.add('animate-visible');
        }, index * 150);
      });
    }, 200);

    // Hide scroll indicator on scroll
    const scrollIndicator = document.getElementById('scroll-indicator');
    let ticking = false;

    function updateScrollIndicator() {
      if (window.scrollY > 100) {
        scrollIndicator?.classList.add('scroll-indicator--hidden');
      } else {
        scrollIndicator?.classList.remove('scroll-indicator--hidden');
      }
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateScrollIndicator);
        ticking = true;
      }
    }, { passive: true });
  })();
</script>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Gradient background layer */
  .hero-gradient-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .hero-gradient-bg::before {
    content: '';
    position: absolute;
    inset: -50%;
    background: 
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(13, 148, 136, 0.12), transparent),
      radial-gradient(ellipse 60% 40% at 80% 50%, rgba(245, 158, 11, 0.08), transparent),
      radial-gradient(ellipse 50% 30% at 20% 80%, rgba(13, 148, 136, 0.06), transparent);
    animation: gradientDrift 20s ease-in-out infinite;
  }

  @keyframes gradientDrift {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(2%, -2%) rotate(1deg); }
    50% { transform: translate(-1%, 2%) rotate(-1deg); }
    75% { transform: translate(-2%, -1%) rotate(0.5deg); }
  }

  /* Particles */
  .particles {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  .particle {
    position: absolute;
    width: 6px;
    height: 6px;
    background: var(--cl-teal);
    border-radius: 50%;
    opacity: 0;
    animation: particleFloat 15s ease-in-out infinite;
  }

  .particle--amber {
    background: var(--cl-amber);
  }

  @keyframes particleFloat {
    0%, 100% { 
      transform: translateY(0) translateX(0);
      opacity: 0;
    }
    10% {
      opacity: 0.4;
    }
    25% { 
      transform: translateY(-40px) translateX(20px);
      opacity: 0.5;
    }
    50% { 
      transform: translateY(-20px) translateX(-10px);
      opacity: 0.3;
    }
    75% { 
      transform: translateY(-50px) translateX(15px);
      opacity: 0.4;
    }
    90% {
      opacity: 0.2;
    }
  }

  /* Hero background image */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(11, 18, 32, 0.5) 0%,
      rgba(11, 18, 32, 0.7) 40%,
      rgba(11, 18, 32, 0.85) 70%,
      var(--cl-bg) 100%
    );
  }

  /* Content */
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding-top: calc(var(--nav-height) + var(--space-2xl));
    padding-bottom: var(--space-2xl);
  }

  .hero-title {
    margin-bottom: var(--space-md);
    line-height: 1.15;
  }

  .hero-line {
    display: block;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s var(--ease-out-expo), transform 0.7s var(--ease-out-expo);
  }

  .hero-line.animate-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .hero-line:first-child {
    margin-bottom: 0.25rem;
  }

  .hero-subtitle {
    color: var(--cl-text-muted);
    font-size: clamp(1.0625rem, 2.5vw, 1.35rem);
    max-width: 40rem;
    margin: 0 auto var(--space-xl);
    line-height: 1.7;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s var(--ease-out-expo) 0.3s, transform 0.7s var(--ease-out-expo) 0.3s;
  }

  .hero-subtitle.animate-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s var(--ease-out-expo) 0.5s, transform 0.7s var(--ease-out-expo) 0.5s;
  }

  .hero-actions.animate-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--cl-text-muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.7;
    animation: bounce 2s infinite;
    z-index: 2;
    transition: opacity 0.3s, visibility 0.3s;
  }

  .scroll-indicator--hidden {
    opacity: 0;
    visibility: hidden;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
    40% { transform: translateX(-50%) translateY(-10px); }
    60% { transform: translateX(-50%) translateY(-5px); }
  }

  .scroll-indicator svg {
    width: 24px;
    height: 24px;
  }

  /* Button pulse glow animation */
  @keyframes pulseGlow {
    0%, 100% { 
      box-shadow: 0 0 20px rgba(13, 148, 136, 0.3), 0 4px 15px rgba(13, 148, 136, 0.2);
    }
    50% { 
      box-shadow: 0 0 35px rgba(13, 148, 136, 0.5), 0 4px 15px rgba(13, 148, 136, 0.3);
    }
  }

  .animate-pulse-glow {
    animation: pulseGlow 2s ease-in-out infinite;
  }

  /* Mobile adjustments */
  @media (max-width: 768px) {
    .hero {
      min-height: 90vh;
    }

    .hero-content {
      padding-top: calc(var(--nav-height) + var(--space-xl));
    }

    .hero-title {
      font-size: clamp(1.75rem, 8vw, 2.5rem);
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .particle {
      display: none;
    }

    .scroll-indicator {
      bottom: 1.5rem;
    }
  }
</style>
