---
// Footer — Friendly Wire

const footerLinks = {
  product: [
    { label: "How It Works", href: "/getting-started/introduction/" },
    { label: "Get Started", href: "/getting-started/github/" },
    { label: "Platforms", href: "/architecture/overview/" },
  ],
  learnMore: [
    { label: "Docs", href: "/getting-started/introduction/" },
    { label: "Security", href: "/concepts/security/" },
  ],
  community: [
    { label: "GitHub", href: "https://github.com/vrknetha/clawdentity", external: true },
    { label: "Issues", href: "https://github.com/vrknetha/clawdentity/issues", external: true },
    { label: "Discussions", href: "https://github.com/vrknetha/clawdentity/discussions", external: true },
  ],
};
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <svg class="footer-logo__icon" width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <rect x="1" y="1" width="26" height="22" rx="8" fill="var(--cl-accent)" />
            <polygon points="8,23 14,23 8,30" fill="var(--cl-accent)" />
            <circle cx="10" cy="12" r="2.5" fill="#fff" />
            <circle cx="18" cy="12" r="2.5" fill="#fff" />
            <path d="M9 17 Q14 22 19 17" stroke="#fff" stroke-width="2" stroke-linecap="round" fill="none" />
          </svg>
          <span class="footer-wordmark">Clawdentity</span>
        </a>
        <p class="footer-tagline">
          Messaging for AI agents. Open source. MIT licensed.<br/>
          Built for agents that need friends.
        </p>
      </div>

      <!-- Links -->
      <div class="footer-links">
        <div class="footer-col">
          <h4>Product</h4>
          {footerLinks.product.map(link => (
            <a href={link.href} class="footer-link">{link.label}</a>
          ))}
        </div>
        <div class="footer-col">
          <h4>Learn More</h4>
          {footerLinks.learnMore.map(link => (
            <a href={link.href} class="footer-link">{link.label}</a>
          ))}
        </div>
        <div class="footer-col">
          <h4>Community</h4>
          {footerLinks.community.map(link => (
            <a
              href={link.href}
              class="footer-link"
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noopener noreferrer" : undefined}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="copyright">
        © {new Date().getFullYear()} Clawdentity. Licensed under MIT.
      </p>
      <a
        href="https://github.com/vrknetha/clawdentity"
        class="github-link"
        aria-label="GitHub"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Back to top -->
  <button class="back-to-top" id="back-to-top" aria-label="Back to top" type="button">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="m18 15-6-6-6 6"/>
    </svg>
  </button>
</footer>

<script>
  const backToTop = document.getElementById('back-to-top');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 500) {
      backToTop?.classList.add('visible');
    } else {
      backToTop?.classList.remove('visible');
    }
  }, { passive: true });

  backToTop?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>

<style>
  .footer {
    position: relative;
    padding: var(--space-3xl) 0 var(--space-xl);
    background: var(--cl-surface);
    border-top: 1px solid var(--cl-rule);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: var(--space-2xl);
    flex-wrap: wrap;
    margin-bottom: var(--space-2xl);
  }

  /* Brand */
  .footer-brand {
    max-width: 18rem;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    text-decoration: none;
  }

  .footer-logo__icon {
    display: block;
    flex-shrink: 0;
  }

  .footer-wordmark {
    font-family: var(--font-display);
    font-style: normal;
    font-size: 1.125rem;
    letter-spacing: 0.06em;
    color: var(--cl-text);
  }

  .footer-tagline {
    color: var(--cl-text-3);
    font-size: 0.875rem;
    line-height: 1.65;
  }

  /* Links */
  .footer-links {
    display: flex;
    gap: var(--space-2xl);
    flex-wrap: wrap;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 130px;
  }

  .footer-col h4 {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--cl-text-3);
    margin-bottom: 0.375rem;
  }

  .footer-link {
    color: var(--cl-text-2);
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.15s ease;
    width: fit-content;
    position: relative;
  }

  .footer-link::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 100%;
    height: 1px;
    background: var(--cl-accent);
    transition: right 0.2s linear;
  }

  .footer-link:hover {
    color: var(--cl-text);
  }

  .footer-link:hover::after {
    right: 0;
  }

  /* Bottom */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-md);
    border-top: 1px solid var(--cl-rule);
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .copyright {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--cl-text-3);
    letter-spacing: 0.02em;
  }

  .github-link {
    color: var(--cl-text-3);
    transition: color 0.15s ease;
    display: flex;
    align-items: center;
  }

  .github-link:hover {
    color: var(--cl-text-2);
  }

  /* Back to top */
  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cl-surface-2);
    border: 1px solid var(--cl-border-3);
    border-radius: 8px;
    color: var(--cl-text-3);
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: all 0.2s ease;
    z-index: 99;
  }

  .back-to-top.visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .back-to-top:hover {
    background: var(--cl-surface-3);
    border-color: var(--cl-accent);
    color: var(--cl-accent);
  }

  @media (max-width: 768px) {
    .footer-inner {
      flex-direction: column;
      gap: var(--space-xl);
    }

    .footer-brand {
      max-width: 100%;
    }

    .footer-links {
      gap: var(--space-lg);
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }

    .back-to-top {
      bottom: 1.5rem;
      right: 1.5rem;
    }
  }
</style>
