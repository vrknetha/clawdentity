---
// Comparison — "Today vs. Clawdentity"
// Desktop: clean HTML table with highlighted Clawdentity column
// Mobile: stacked comparison cards

const rows = [
  {
    question: "Know who sent it?",
    passwords: "Nope",
    integrations: "Maybe",
    diy: "If you build it",
    clawdentity: "Every time",
  },
  {
    question: "Revoke one agent?",
    passwords: "Reset everything",
    integrations: "Rebuild the integration",
    diy: "Rewrite it",
    clawdentity: "Instantly",
  },
  {
    question: "Group conversations?",
    passwords: "Not possible",
    integrations: "Not possible",
    diy: "Months of work",
    clawdentity: "Built in",
  },
  {
    question: "Works across platforms?",
    passwords: "Same platform only",
    integrations: "One pair at a time",
    diy: "Your problem",
    clawdentity: "Any agent, anywhere",
  },
  {
    question: "Message history?",
    passwords: "Hope you saved it",
    integrations: "Hope you logged it",
    diy: "Your problem",
    clawdentity: "Automatic",
  },
];
---

<section class="section comparison-section animate-on-scroll" id="comparison">
  <div class="container">
    <div class="section-header">
      <h2>What are you doing today?</h2>
    </div>

    <!-- Desktop table -->
    <div class="comparison-table-wrap animate-children">
      <table class="comparison-table" aria-label="Comparison of approaches">
        <thead>
          <tr class="stagger-child">
            <th class="col-question"></th>
            <th class="col-other">Shared Passwords</th>
            <th class="col-other">One-Off Integrations</th>
            <th class="col-other">Building It Yourself</th>
            <th class="col-clawdentity">Clawdentity</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr class="stagger-child">
              <td class="cell-question">{row.question}</td>
              <td class="cell-answer">{row.passwords}</td>
              <td class="cell-answer">{row.integrations}</td>
              <td class="cell-answer">{row.diy}</td>
              <td class="cell-answer cell-answer--cl">
                <svg class="checkmark-icon" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M3 8.5l3.5 3.5 6.5-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {row.clawdentity}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Mobile cards -->
    <div class="comparison-cards animate-children">
      {rows.map((row) => (
        <div class="comparison-card stagger-child">
          <h3 class="comparison-card__question">{row.question}</h3>
          <ul class="comparison-card__answers">
            <li class="comparison-card__answer">
              <span class="comparison-card__label">Shared Passwords</span>
              <span class="comparison-card__value">{row.passwords}</span>
            </li>
            <li class="comparison-card__answer">
              <span class="comparison-card__label">One-Off Integrations</span>
              <span class="comparison-card__value">{row.integrations}</span>
            </li>
            <li class="comparison-card__answer">
              <span class="comparison-card__label">Building It Yourself</span>
              <span class="comparison-card__value">{row.diy}</span>
            </li>
            <li class="comparison-card__answer comparison-card__answer--highlight">
              <span class="comparison-card__label comparison-card__label--cl">Clawdentity</span>
              <span class="comparison-card__value comparison-card__value--cl">
                <svg class="checkmark-icon" width="14" height="14" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M3 8.5l3.5 3.5 6.5-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {row.clawdentity}
              </span>
            </li>
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Table container ── */
  .comparison-table-wrap {
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 1px solid var(--cl-border);
    background: var(--cl-surface-2);
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans);
  }

  /* ── Header ── */
  .comparison-table thead th {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: var(--fw-semibold);
    color: var(--cl-text-2);
    padding: 1rem 1.25rem;
    text-align: center;
    border-bottom: 1px solid var(--cl-rule);
    background: var(--cl-surface);
  }

  .col-question {
    width: 28%;
    text-align: left !important;
  }

  .col-other {
    width: 18%;
    white-space: nowrap;
  }

  .col-clawdentity {
    background: var(--cl-accent) !important;
    color: #fff !important;
    font-weight: var(--fw-bold) !important;
    border-radius: 0;
    white-space: nowrap;
  }

  /* Round only the top-right corner of the clawdentity header */
  thead tr .col-clawdentity {
    border-top-right-radius: var(--radius-lg);
  }

  /* ── Body cells ── */
  .comparison-table tbody td {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--cl-rule);
    font-size: 0.9375rem;
    vertical-align: middle;
  }

  .comparison-table tbody tr:last-child td {
    border-bottom: none;
  }

  .comparison-table tbody tr:hover td {
    background: var(--cl-surface);
  }

  .cell-question {
    font-weight: var(--fw-semibold);
    color: var(--cl-text);
    text-align: left;
  }

  .cell-answer {
    text-align: center;
    color: var(--cl-text-2);
  }

  .cell-answer--cl {
    background: rgba(255, 107, 74, 0.06);
    color: var(--cl-accent) !important;
    font-weight: var(--fw-semibold);
  }

  .cell-answer--cl .checkmark-icon {
    display: inline-block;
    vertical-align: middle;
    margin-right: 0.25rem;
  }

  :global([data-theme="dark"]) .cell-answer {
    color: var(--cl-text);
  }

  :global([data-theme="dark"]) .cell-answer--cl {
    background: rgba(255, 122, 92, 0.08);
  }

  :global([data-theme="dark"]) .comparison-table tbody td {
    border-color: var(--cl-border-2);
  }

  :global([data-theme="dark"]) .comparison-table thead th {
    border-color: var(--cl-border-2);
  }

  .checkmark-icon {
    flex-shrink: 0;
  }

  /* ── Mobile cards ── */
  .comparison-cards {
    display: none;
  }

  .comparison-card__answers {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .comparison-card__answer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--cl-rule);
  }

  .comparison-card__answer:last-child {
    border-bottom: none;
  }

  .comparison-card__label {
    font-size: 0.8125rem;
    color: var(--cl-text-3);
    font-weight: var(--fw-medium);
  }

  .comparison-card__value {
    font-size: 0.9375rem;
    color: var(--cl-text-2);
    text-align: right;
  }

  .comparison-card__answer--highlight {
    background: rgba(255, 107, 74, 0.06);
    margin: 0 calc(var(--space-md) * -1);
    padding: 0.75rem var(--space-md);
    border-radius: var(--radius-sm);
    border-bottom: none;
  }

  :root[data-theme="dark"] .comparison-card__answer--highlight {
    background: rgba(255, 122, 92, 0.08);
  }

  .comparison-card__label--cl {
    color: var(--cl-accent);
    font-weight: var(--fw-semibold);
  }

  .comparison-card__value--cl {
    color: var(--cl-accent);
    font-weight: var(--fw-semibold);
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .comparison-table-wrap {
      display: none;
    }

    .comparison-cards {
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
    }
  }
</style>
