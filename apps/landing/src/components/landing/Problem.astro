---
import { Image } from "astro:assets";
import identityIcon from "../../assets/landing/clawdentity_feature_identity_256.png";
import communicationIcon from "../../assets/landing/clawdentity_feature_communication_256.png";
import trustIcon from "../../assets/landing/clawdentity_feature_trust_256.png";

const problems = [
  {
    icon: identityIcon,
    title: "No Per-Agent Identity",
    description:
      "Receivers cannot prove which exact agent sent a request or who owns it. Any caller with the shared token looks the same to the gateway.",
  },
  {
    icon: communicationIcon,
    title: "Shared-Secret Blast Radius",
    description:
      "If one token leaks, any caller can impersonate a trusted agent until rotation. One leak exposes every integration.",
  },
  {
    icon: trustIcon,
    title: "Weak Revocation Model",
    description:
      "Disabling one compromised agent means rotating shared credentials across all integrations. No way to revoke a single identity.",
  },
];
---

<section class="section problem-section animate-on-scroll" id="problem">
  <div class="container">
    <div class="section-header">
      <span class="section-label">The Challenge</span>
      <h2>The Problem with Shared Tokens</h2>
      <p>
        Shared gateway tokens work for transport, but not for identity-aware agent systems.
      </p>
    </div>

    <div class="problem-grid">
      {problems.map((problem, index) => (
        <div class="problem-card stagger-child" style={`transition-delay: ${index * 100}ms`}>
          <div class="problem-glow"></div>
          <div class="problem-accent"></div>
          <div class="problem-icon-wrapper">
            <div class="problem-icon">
              <Image
                src={problem.icon}
                alt=""
                width={80}
                height={80}
                format="webp"
                quality={90}
              />
            </div>
            <div class="problem-icon-glow"></div>
          </div>
          <h3>{problem.title}</h3>
          <p>{problem.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .problem-section {
    position: relative;
  }

  .problem-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse 60% 40% at 20% 50%, rgba(245, 158, 11, 0.03), transparent),
      radial-gradient(ellipse 40% 60% at 80% 30%, rgba(245, 158, 11, 0.02), transparent);
    pointer-events: none;
  }

  .section-label {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: rgba(245, 158, 11, 0.1);
    border: 1px solid rgba(245, 158, 11, 0.2);
    border-radius: 2rem;
    color: var(--cl-amber);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-sm);
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-md);
    position: relative;
    z-index: 1;
  }

  .problem-card {
    position: relative;
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.03), transparent);
    border: 1px solid var(--cl-border);
    border-left: 3px solid var(--cl-amber);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-align: center;
    transition: all var(--duration-normal) var(--ease-smooth);
    overflow: hidden;
  }

  .problem-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, var(--cl-amber), transparent);
    opacity: 0.3;
  }

  .problem-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(245, 158, 11, 0.1) 0%, transparent 60%);
    opacity: 0;
    transition: opacity var(--duration-normal);
    pointer-events: none;
  }

  .problem-card:hover .problem-glow {
    opacity: 1;
  }

  .problem-accent {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(to bottom, var(--cl-amber), var(--cl-amber-light));
  }

  .problem-icon-wrapper {
    position: relative;
    display: inline-block;
    margin-bottom: var(--space-md);
  }

  .problem-icon {
    position: relative;
    width: 5rem;
    height: 5rem;
    margin: 0 auto;
    z-index: 1;
  }

  .problem-icon :global(img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform var(--duration-normal) var(--ease-smooth);
  }

  .problem-icon-glow {
    position: absolute;
    inset: -20%;
    background: radial-gradient(circle, rgba(245, 158, 11, 0.3) 0%, transparent 70%);
    opacity: 0;
    transition: opacity var(--duration-normal);
    pointer-events: none;
  }

  .problem-card:hover .problem-icon-glow {
    opacity: 1;
  }

  .problem-card:hover .problem-icon :global(img) {
    transform: scale(1.05);
  }

  .problem-card h3 {
    margin-bottom: var(--space-xs);
    color: var(--cl-text);
    font-size: 1.25rem;
  }

  .problem-card p {
    color: var(--cl-text-muted);
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .problem-grid {
      grid-template-columns: 1fr;
    }

    .problem-card {
      padding: var(--space-lg);
    }

    .problem-icon {
      width: 4rem;
      height: 4rem;
    }
  }
</style>
