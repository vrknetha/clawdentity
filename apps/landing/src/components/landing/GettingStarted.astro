---
// GettingStarted — Section 07
// Agent-first: give your AI agent one URL

const agentPrompt = `Read the instructions from https://clawdentity.com/skill.md and follow the instructions`;
---

<section class="section getting-started-section animate-on-scroll" id="getting-started">
  <div class="container">
    <div class="section-header">
      <span class="section-number">07 —</span>
      <h2>Give your agent this prompt.</h2>
    </div>

    <div class="agent-block stagger-child">
      <div class="agent-block__header">
        <span class="agent-block__label">AGENT-FIRST SETUP</span>
        <button class="agent-block__copy" id="prompt-copy" aria-label="Copy agent prompt" type="button">
          <svg class="copy-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2"/>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          <svg class="check-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 6L9 17l-5-5"/>
          </svg>
          <span>Copy</span>
        </button>
      </div>
      <div class="agent-block__content">
        <code class="agent-prompt">{agentPrompt}</code>
      </div>
      <p class="agent-block__note">Your agent handles install, config, and identity setup.</p>
    </div>

    <div class="cta-row stagger-child" style="transition-delay: 300ms">
      <a href="/getting-started/quickstart/" class="btn btn-primary">
        Read the Quick Start Guide
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<script define:vars={{ agentPrompt }}>
  document.getElementById('prompt-copy')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(agentPrompt);
      const btn = document.getElementById('prompt-copy');
      btn?.classList.add('copied');
      setTimeout(() => btn?.classList.remove('copied'), 2000);
    } catch { /* silently fail */ }
  });
</script>

<style>
  /* Tighten gap between heading and block */
  .getting-started-section .section-header {
    margin-bottom: var(--space-lg);
  }

  /* Outer wrapper — uses surface-2 so it contrasts against page bg in both themes */
  .agent-block {
    max-width: 640px;
    background: var(--cl-surface-2);
    border: 1px solid var(--cl-border-3);
    border-left: 2px solid var(--cl-accent);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: var(--space-xl);
  }

  /* Header bar — slightly darker strip inside the card */
  .agent-block__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 1rem;
    background: var(--cl-surface-3);
    border-bottom: 1px solid var(--cl-border-2);
  }

  .agent-block__label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-variant: small-caps;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cl-accent);
  }

  .agent-block__copy {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.3rem 0.625rem;
    background: transparent;
    border: 1px solid var(--cl-border-3);
    border-radius: 2px;
    color: var(--cl-text-2);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .agent-block__copy:hover {
    color: var(--cl-text);
    border-color: var(--cl-accent);
  }

  .agent-block__copy.copied {
    color: #6A9955;
    border-color: #6A9955;
  }

  .agent-block__copy .check-icon { display: none; }
  .agent-block__copy.copied .check-icon { display: block; }
  .agent-block__copy.copied .copy-icon { display: none; }

  /* Inner code area — always dark, like a code block */
  .agent-block__content {
    padding: 1.25rem 1rem;
    background: var(--cl-code-bg);
    border-bottom: 1px solid var(--cl-border-2);
  }

  .agent-prompt {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: #E6EDF3;
    line-height: 1.6;
    display: block;
    word-break: break-word;
  }

  /* Footer note — back in the surface-2 card bg */
  .agent-block__note {
    padding: 0.75rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--cl-text-2);
    margin: 0;
  }

  .cta-row {
    margin-top: var(--space-md);
  }

  @media (max-width: 640px) {
    .agent-block__header {
      padding: 0.5rem 0.75rem;
    }

    .agent-block__content {
      padding: 1rem 0.75rem;
    }

    .agent-prompt {
      font-size: 0.8125rem;
    }

    .agent-block__copy span {
      display: none;
    }
  }
</style>
