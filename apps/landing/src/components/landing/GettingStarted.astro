---
// GettingStarted — Section 07
// Agent-first: give your AI agent one URL
import {
  GITHUB_ONBOARDING_START_URL,
} from "./onboarding";
---

<section class="section getting-started-section animate-on-scroll" id="getting-started">
  <div class="container">
    <div class="section-header">
      <span class="section-number">07 —</span>
      <h2>Hosted onboarding starts with GitHub.</h2>
    </div>

    <p class="getting-started-intro stagger-child">
      Public onboarding is now one GitHub sign-in, one starter pass, and one first agent. The
      prompt is generated only after the GitHub redirect lands on the starter-pass page. Private or
      self-hosted installs still use operator-issued invites and the advanced docs.
    </p>

    <div class="flow-card stagger-child">
      <span class="flow-card__label">HOSTED FLOW</span>
      <ol class="flow-card__steps">
        <li>Start with GitHub sign-in.</li>
        <li>Finish onboarding and land on <code>/getting-started/github/</code>.</li>
        <li>Copy the generated prompt from that page into OpenClaw.</li>
      </ol>
      <p class="flow-card__note">
        If you run a private or self-hosted rollout, use the operator docs and invite-based flow
        instead of the hosted starter-pass path.
      </p>
    </div>

    <div class="cta-row stagger-child" style="transition-delay: 300ms">
      <a href={GITHUB_ONBOARDING_START_URL} class="btn btn-primary">
        Get Started with GitHub
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
      <a href="/getting-started/quickstart/" class="btn btn-secondary">
        Read the Quick Start Guide
      </a>
    </div>
  </div>
</section>

<style>
  /* Tighten gap between heading and block */
  .getting-started-section .section-header {
    margin-bottom: var(--space-sm);
  }

  .getting-started-intro {
    max-width: 42rem;
    margin: 0 0 var(--space-lg);
    color: var(--cl-text-2);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .flow-card {
    max-width: 640px;
    background: var(--cl-surface-2);
    border: 1px solid var(--cl-border-3);
    border-left: 2px solid var(--cl-accent);
    border-radius: 4px;
    padding: 1.125rem 1rem;
    margin-bottom: var(--space-xl);
  }

  .flow-card__label {
    display: block;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-variant: small-caps;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cl-accent);
  }

  .flow-card__steps {
    margin: 0;
    padding-left: 1.125rem;
    color: var(--cl-text);
    line-height: 1.75;
  }

  .flow-card__steps li + li {
    margin-top: 0.25rem;
  }

  .flow-card__note {
    margin: 0.875rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--cl-text-2);
    line-height: 1.6;
  }

  .cta-row {
    margin-top: var(--space-md);
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  @media (max-width: 640px) {
    .flow-card {
      padding: 1rem 0.875rem;
    }
  }
</style>
