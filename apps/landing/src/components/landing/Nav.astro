---
// Nav — Iron Ledger design
import iconSrc from "../../assets/landing/clawdentity_icon_only.svg?url";
---

<nav class="nav" id="nav">
  <div class="nav-inner container">
    <!-- Logotype -->
    <a href="/" class="nav-logo" aria-label="Clawdentity home">
      <img src={iconSrc} alt="" class="nav-logo__icon" width="28" height="28" aria-hidden="true" />
      <span class="nav-logo__wordmark">Clawdentity</span>
    </a>

    <div class="nav-links" id="nav-links">
      <a href="/getting-started/introduction/" class="nav-link nav-link-underline">
        <span>Docs</span>
      </a>
      <a href="/getting-started/quickstart/" class="nav-link nav-link-underline">
        <span>Quick Start</span>
      </a>
      <a
        href="https://github.com/vrknetha/clawdentity"
        class="nav-link nav-link--icon"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub repository"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>

      <!-- Theme toggle -->
      <button
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle light/dark mode"
        type="button"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg class="theme-icon theme-icon--sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="theme-icon theme-icon--moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>

    <button
      class="nav-toggle"
      id="nav-toggle"
      aria-label="Toggle navigation"
      aria-expanded="false"
    >
      <span class="nav-toggle__line"></span>
      <span class="nav-toggle__line"></span>
      <span class="nav-toggle__line"></span>
    </button>
  </div>
</nav>

<script>
  // Theme toggle
  (function() {
    const toggle = document.getElementById('theme-toggle');
    const html = document.documentElement;

    function getTheme(): string {
      return html.getAttribute('data-theme') ?? 'dark';
    }

    function setTheme(theme: string) {
      html.setAttribute('data-theme', theme);
      localStorage.setItem('cl-theme', theme);
    }

    toggle?.addEventListener('click', () => {
      setTheme(getTheme() === 'dark' ? 'light' : 'dark');
    });
  })();

  // Navigation scroll behavior
  (function() {
    const nav = document.getElementById('nav');
    const navToggle = document.getElementById('nav-toggle');
    const navLinks = document.getElementById('nav-links');
    const MOBILE_BREAKPOINT = 768;

    let lastScrollY = window.scrollY;
    let ticking = false;
    let isMenuOpen = false;

    function syncBodyScrollLock() {
      const shouldLock = isMenuOpen && window.innerWidth <= MOBILE_BREAKPOINT;
      document.body.style.overflow = shouldLock ? 'hidden' : '';
    }

    function setMenuOpen(nextOpen: boolean) {
      isMenuOpen = nextOpen;
      navToggle?.setAttribute('aria-expanded', isMenuOpen.toString());
      nav?.classList.toggle('nav--open', isMenuOpen);
      syncBodyScrollLock();
    }

    function updateNav() {
      const currentScrollY = window.scrollY;

      if (currentScrollY > 50) {
        nav?.classList.add('nav--scrolled');
      } else {
        nav?.classList.remove('nav--scrolled');
      }

      if (window.innerWidth > MOBILE_BREAKPOINT) {
        if (currentScrollY > lastScrollY && currentScrollY > 100) {
          nav?.classList.add('nav--hidden');
        } else {
          nav?.classList.remove('nav--hidden');
        }
      }

      lastScrollY = currentScrollY;
      ticking = false;
    }

    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(updateNav);
        ticking = true;
      }
    }, { passive: true });

    navToggle?.addEventListener('click', function() {
      setMenuOpen(!isMenuOpen);
    });

    navLinks?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        if (isMenuOpen) setMenuOpen(false);
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isMenuOpen) setMenuOpen(false);
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth > MOBILE_BREAKPOINT && isMenuOpen) {
        setMenuOpen(false);
        return;
      }
      syncBodyScrollLock();
    });

    syncBodyScrollLock();
  })();
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-height);
    background: transparent;
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease,
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    border-bottom: 1px solid transparent;
  }

  .nav--scrolled {
    background: color-mix(in srgb, var(--cl-bg) 96%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom-color: var(--cl-rule);
  }

  .nav--hidden {
    transform: translateY(-100%);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: var(--space-md);
  }

  /* Logotype */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .nav-logo__icon {
    display: block;
    flex-shrink: 0;
  }

  .nav-logo__wordmark {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.0625rem;
    color: var(--cl-text);
    letter-spacing: 0.04em;
    line-height: 1;
  }

  /* Links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    position: relative;
    display: flex;
    align-items: center;
    padding: 0.5rem 0.75rem;
    color: var(--cl-text-2);
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--cl-text);
  }

  /* Underline slide animation */
  .nav-link-underline {
    position: relative;
  }

  .nav-link-underline::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0.75rem;
    right: 100%;
    height: 1px;
    background: var(--cl-accent);
    transition: right 0.2s linear;
  }

  .nav-link-underline:hover::after {
    right: 0.75rem;
  }

  .nav-link--icon {
    padding: 0.5rem;
    color: var(--cl-text-3);
  }

  .nav-link--icon:hover {
    color: var(--cl-text-2);
  }

  /* Theme toggle */
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--cl-border-2);
    border-radius: 2px;
    color: var(--cl-text-3);
    cursor: pointer;
    transition:
      border-color var(--duration-normal) ease,
      color var(--duration-normal) ease;
  }

  .theme-toggle:hover {
    border-color: var(--cl-border-3);
    color: var(--cl-text-2);
  }

  /* Show sun in dark mode, moon in light mode */
  :root[data-theme="dark"] .theme-icon--moon { display: none; }
  :root[data-theme="dark"] .theme-icon--sun { display: block; }
  :root[data-theme="light"] .theme-icon--sun { display: none; }
  :root[data-theme="light"] .theme-icon--moon { display: block; }

  /* Mobile toggle */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    gap: 5px;
    position: relative;
    z-index: 101;
  }

  .nav-toggle__line {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--cl-text);
    transition: all 0.3s ease;
    transform-origin: center;
  }

  .nav--open .nav-toggle__line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }

  .nav--open .nav-toggle__line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .nav--open .nav-toggle__line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
    }

    .nav-links {
      position: fixed;
      top: var(--nav-height);
      left: 0;
      right: 0;
      bottom: 0;
      background: color-mix(in srgb, var(--cl-bg) 98%, transparent);
      backdrop-filter: blur(8px);
      flex-direction: column;
      justify-content: flex-start;
      align-items: center;
      padding-top: var(--space-2xl);
      gap: var(--space-xs);
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
      transition: all 0.3s ease;
    }

    .nav--open .nav-links {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .nav-link {
      font-size: 1.125rem;
      padding: 0.75rem 1.5rem;
    }
  }

  .nav-link:focus-visible,
  .nav-toggle:focus-visible,
  .theme-toggle:focus-visible {
    outline: 1px solid var(--cl-accent);
    outline-offset: 2px;
  }
</style>
